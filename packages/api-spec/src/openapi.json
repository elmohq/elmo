{
	"openapi": "3.0.3",
	"info": {
		"title": "API",
		"description": "API for managing prompts and generating AI Share of Voice reports.",
		"version": "1.0.0",
		"contact": {
			"name": "API Support"
		}
	},
	"servers": [
		{
			"url": "/api/v1",
			"description": "API"
		}
	],
	"security": [
		{
			"BearerAuth": []
		}
	],
	"components": {
		"securitySchemes": {
			"BearerAuth": {
				"type": "http",
				"scheme": "bearer",
				"description": "Bearer API token for access"
			}
		},
		"schemas": {
			"Prompt": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"description": "Unique identifier for the prompt"
					},
					"brandId": {
						"type": "string",
						"description": "Brand identifier this prompt belongs to"
					},
					"value": {
						"type": "string",
						"description": "The actual prompt text"
					},
					"enabled": {
						"type": "boolean",
						"description": "Whether the prompt is currently enabled"
					},
					"tags": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "User-defined tags for categorizing this prompt"
					},
					"systemTags": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "Auto-computed system tags (e.g., 'branded', 'unbranded'). Read-only."
					},
					"createdAt": {
						"type": "string",
						"format": "date-time",
						"description": "Timestamp when the prompt was created"
					},
					"updatedAt": {
						"type": "string",
						"format": "date-time",
						"description": "Timestamp when the prompt was last updated"
					}
				},
				"required": ["id", "brandId", "value", "enabled", "tags", "systemTags", "createdAt", "updatedAt"]
			},
			"CreatePromptRequest": {
				"type": "object",
				"properties": {
					"brandId": {
						"type": "string",
						"description": "Brand identifier this prompt belongs to"
					},
					"value": {
						"type": "string",
						"description": "The prompt text",
						"minLength": 1
					},
					"tags": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "User-defined tags for categorizing this prompt"
					}
				},
				"required": ["brandId", "value"]
			},
			"UpdatePromptRequest": {
				"type": "object",
				"properties": {
					"value": {
						"type": "string",
						"description": "The prompt text",
						"minLength": 1
					},
					"enabled": {
						"type": "boolean",
						"description": "Whether the prompt is enabled"
					},
					"tags": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "User-defined tags for categorizing this prompt"
					}
				}
			},
			"Error": {
				"type": "object",
				"properties": {
					"error": {
						"type": "string",
						"description": "Error type"
					},
					"message": {
						"type": "string",
						"description": "Detailed error message"
					}
				},
				"required": ["error"]
			},
			"SuccessMessage": {
				"type": "object",
				"properties": {
					"message": {
						"type": "string",
						"description": "Success message"
					},
					"data": {
						"type": "object",
						"description": "Additional response data"
					}
				},
				"required": ["message"]
			},
			"CreateReportRequest": {
				"type": "object",
				"properties": {
					"brandName": {
						"type": "string",
						"description": "The brand name to analyze",
						"minLength": 1
					},
					"brandWebsite": {
						"type": "string",
						"description": "The brand's website URL",
						"minLength": 1
					},
					"manualPrompts": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "Optional list of custom prompts to include in the report"
					}
				},
				"required": ["brandName", "brandWebsite"]
			},
			"ReportSummary": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"description": "Unique identifier for the report"
					},
					"brandName": {
						"type": "string",
						"description": "Brand name analyzed"
					},
					"brandWebsite": {
						"type": "string",
						"description": "Brand website URL"
					},
					"status": {
						"type": "string",
						"enum": ["pending", "processing", "completed", "failed"],
						"description": "Current report status"
					},
					"createdAt": {
						"type": "string",
						"format": "date-time",
						"description": "Timestamp when the report was created"
					},
					"completedAt": {
						"type": "string",
						"format": "date-time",
						"nullable": true,
						"description": "Timestamp when the report completed"
					}
				},
				"required": ["id", "brandName", "brandWebsite", "status", "createdAt"]
			},
			"ReportPromptSnapshot": {
				"type": "object",
				"description": "Per-prompt snapshot of raw mention data from a report. Consumers compute SoV and other derived metrics.",
				"properties": {
					"promptValue": {
						"type": "string",
						"description": "The prompt text that was evaluated"
					},
					"totalRuns": {
						"type": "integer",
						"description": "Number of evaluation runs for this prompt"
					},
					"mentions": {
						"$ref": "#/components/schemas/MentionsSummary"
					}
				},
				"required": ["promptValue", "totalRuns", "mentions"]
			},
			"MentionsSummary": {
				"type": "object",
				"description": "Aggregated mention counts for a prompt across its evaluation runs.",
				"properties": {
					"mentionsTotal": {
						"type": "integer",
						"description": "Total brand + competitor mentions across all runs"
					},
					"brandMentionsTotal": {
						"type": "integer",
						"description": "Number of runs where the brand was mentioned"
					},
					"competitorMentionsTotal": {
						"type": "integer",
						"description": "Total count of individual competitor mentions across all runs (a single run mentioning 3 competitors counts as 3)"
					},
					"mentionsTopK": {
						"type": "array",
						"items": {
							"$ref": "#/components/schemas/MentionEntry"
						},
						"description": "Top-K competitor entities ranked by mention count"
					}
				},
				"required": ["mentionsTotal", "brandMentionsTotal", "competitorMentionsTotal", "mentionsTopK"]
			},
			"MentionEntry": {
				"type": "object",
				"properties": {
					"entity": {
						"type": "string",
						"description": "Competitor entity name"
					},
					"count": {
						"type": "integer",
						"description": "Number of runs where this entity was mentioned"
					}
				},
				"required": ["entity", "count"]
			},
			"CitedUrlEntry": {
				"type": "object",
				"properties": {
					"url": {
						"type": "string",
						"description": "The cited URL"
					},
					"title": {
						"type": "string",
						"nullable": true,
						"description": "Page title if available"
					},
					"count": {
						"type": "integer",
						"description": "Number of times this URL was cited"
					}
				},
				"required": ["url", "title", "count"]
			},
			"OnboardingAnalyzeRequest": {
				"type": "object",
				"properties": {
					"website": {
						"type": "string",
						"description": "Brand's website URL or hostname",
						"minLength": 1
					},
					"brandName": {
						"type": "string",
						"description": "Optional brand name hint. If omitted, inferred from the domain."
					},
					"includeCompetitors": {
						"type": "boolean",
						"description": "Whether to include competitor suggestions (default true)",
						"default": true
					},
					"includePrompts": {
						"type": "boolean",
						"description": "Whether to include prompt suggestions (default true)",
						"default": true
					},
					"maxCompetitors": {
						"type": "integer",
						"description": "Maximum number of competitor suggestions",
						"minimum": 1,
						"maximum": 100,
						"default": 10
					},
					"maxPrompts": {
						"type": "integer",
						"description": "Maximum number of suggested prompts",
						"minimum": 1,
						"maximum": 100,
						"default": 30
					}
				},
				"required": ["website"]
			},
			"OnboardingSuggestion": {
				"type": "object",
				"properties": {
					"brandName": { "type": "string" },
					"website": { "type": "string", "description": "Cleaned hostname" },
					"additionalDomains": { "type": "array", "items": { "type": "string" } },
					"aliases": { "type": "array", "items": { "type": "string" } },
					"competitors": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": { "type": "string" },
								"domains": { "type": "array", "items": { "type": "string" } },
								"aliases": { "type": "array", "items": { "type": "string" } }
							},
							"required": ["name", "domains", "aliases"]
						}
					},
					"suggestedPrompts": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"prompt": { "type": "string" },
								"tags": { "type": "array", "items": { "type": "string" } }
							},
							"required": ["prompt", "tags"]
						}
					}
				},
				"required": [
					"brandName",
					"website",
					"additionalDomains",
					"aliases",
					"competitors",
					"suggestedPrompts"
				]
			},
			"OnboardBrandRequest": {
				"type": "object",
				"description": "Create a brand and (optionally) auto-generate competitors and prompts. Fails with 409 if a brand with this brandId already exists — use PATCH /onboarding/brands/{brandId} to update.",
				"properties": {
					"brandId": { "type": "string", "minLength": 1 },
					"brandName": { "type": "string", "minLength": 1 },
					"website": { "type": "string", "minLength": 1 },
					"additionalDomains": {
						"type": "array",
						"items": { "type": "string" },
						"description": "Other domains the brand owns. Will be merged with anything the LLM finds."
					},
					"aliases": {
						"type": "array",
						"items": { "type": "string" },
						"description": "Other names the brand goes by. Merged with LLM suggestions."
					},
					"competitors": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": { "type": "string", "minLength": 1 },
								"domains": { "type": "array", "items": { "type": "string" } },
								"aliases": { "type": "array", "items": { "type": "string" } }
							},
							"required": ["name"]
						},
						"description": "Caller-supplied competitors. If provided, generateCompetitors is ignored."
					},
					"prompts": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"value": { "type": "string", "minLength": 1 },
								"tags": { "type": "array", "items": { "type": "string" } },
								"enabled": { "type": "boolean", "default": true }
							},
							"required": ["value"]
						},
						"description": "Caller-supplied prompts. If provided, generatePrompts is ignored."
					},
					"generateCompetitors": { "type": "boolean", "default": true },
					"generatePrompts": { "type": "boolean", "default": true }
				},
				"required": ["brandId", "brandName", "website"]
			},
			"UpdateOnboardedBrandRequest": {
				"type": "object",
				"description": "Top up an existing brand. brandId comes from the URL path; all body fields are optional. Domains and aliases are merged into the existing arrays. New competitors are deduped against existing ones by domain overlap. New prompts are deduped against existing prompts by lowercased value.",
				"properties": {
					"brandName": { "type": "string", "minLength": 1, "description": "If provided, replaces the brand's stored name." },
					"website": { "type": "string", "minLength": 1, "description": "If provided, replaces the brand's stored website." },
					"additionalDomains": {
						"type": "array",
						"items": { "type": "string" },
						"description": "Other domains the brand owns. Merged into the existing additionalDomains list."
					},
					"aliases": {
						"type": "array",
						"items": { "type": "string" },
						"description": "Other names the brand goes by. Merged into the existing aliases list."
					},
					"competitors": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"name": { "type": "string", "minLength": 1 },
								"domains": { "type": "array", "items": { "type": "string" } },
								"aliases": { "type": "array", "items": { "type": "string" } }
							},
							"required": ["name"]
						},
						"description": "Net-new competitors to add. Skipped if any of their domains overlap an existing competitor's."
					},
					"prompts": {
						"type": "array",
						"items": {
							"type": "object",
							"properties": {
								"value": { "type": "string", "minLength": 1 },
								"tags": { "type": "array", "items": { "type": "string" } },
								"enabled": { "type": "boolean", "default": true }
							},
							"required": ["value"]
						},
						"description": "Net-new prompts to add. Skipped if a prompt with the same lowercased value already exists for this brand."
					},
					"generateCompetitors": { "type": "boolean", "default": false, "description": "Run analyzeBrand to suggest more competitors. Default false; only runs if `competitors` is empty." },
					"generatePrompts": { "type": "boolean", "default": false, "description": "Run analyzeBrand to suggest more prompts. Default false; only runs if `prompts` is empty." }
				}
			},
			"OnboardBrandResponse": {
				"type": "object",
				"properties": {
					"brandId": { "type": "string" },
					"brandName": { "type": "string" },
					"website": { "type": "string" },
					"additionalDomains": { "type": "array", "items": { "type": "string" } },
					"aliases": { "type": "array", "items": { "type": "string" } },
					"promptsCreated": { "type": "integer" },
					"competitorsCreated": { "type": "integer" },
					"suggestion": {
						"oneOf": [
							{ "$ref": "#/components/schemas/OnboardingSuggestion" },
							{ "type": "null" }
						],
						"description": "The raw LLM suggestion when generation ran; null when caller supplied everything."
					}
				},
				"required": ["brandId", "brandName", "website", "additionalDomains", "aliases", "promptsCreated", "competitorsCreated"]
			},
			"PromptSnapshot": {
				"type": "object",
				"properties": {
					"brandId": {
						"type": "string",
						"description": "Brand identifier this prompt belongs to"
					},
					"promptId": {
						"type": "string",
						"format": "uuid",
						"description": "Unique identifier for the prompt"
					},
					"promptValue": {
						"type": "string",
						"description": "The prompt text"
					},
					"startDate": {
						"type": "string",
						"format": "date",
						"description": "Start of the queried date range (YYYY-MM-DD)"
					},
					"endDate": {
						"type": "string",
						"format": "date",
						"description": "End of the queried date range (YYYY-MM-DD)"
					},
					"mentions": {
						"$ref": "#/components/schemas/MentionsSummary"
					},
					"citations": {
						"type": "object",
						"properties": {
							"citationsTotal": {
								"type": "integer",
								"description": "Total number of citations across all runs"
							},
							"brandCitationsTotal": {
								"type": "integer",
								"description": "Number of citations to brand-owned domains"
							},
							"competitorCitationsTotal": {
								"type": "integer",
								"description": "Number of citations to competitor-owned domains"
							},
							"citedUrlsTopK": {
								"type": "array",
								"items": {
									"$ref": "#/components/schemas/CitedUrlEntry"
								},
								"description": "Top-K cited URLs ranked by frequency"
							}
						},
						"required": ["citationsTotal", "brandCitationsTotal", "competitorCitationsTotal", "citedUrlsTopK"]
					}
				},
				"required": ["brandId", "promptId", "promptValue", "startDate", "endDate", "mentions", "citations"]
			}
		},
		"responses": {
			"UnauthorizedError": {
				"description": "Authentication required",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			},
			"NotFoundError": {
				"description": "Resource not found",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			},
			"ValidationError": {
				"description": "Invalid request data",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			},
			"InternalServerError": {
				"description": "Internal server error",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			},
			"ConflictError": {
				"description": "Resource already exists",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			}
		}
	},
	"paths": {
		"/onboarding/analyze": {
			"post": {
				"summary": "Analyze a brand for onboarding",
				"description": "Run the provider-agnostic brand analysis (additional domains, aliases, competitors, suggested prompts) without persisting anything. The LLM is selected automatically based on configured API keys (Anthropic / OpenAI / OpenRouter / Olostep / BrightData).",
				"operationId": "analyzeBrandForOnboarding",
				"tags": ["Onboarding"],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/OnboardingAnalyzeRequest" }
						}
					}
				},
				"responses": {
					"200": {
						"description": "Brand analysis suggestion",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/OnboardingSuggestion" }
							}
						}
					},
					"400": { "$ref": "#/components/responses/ValidationError" },
					"401": { "$ref": "#/components/responses/UnauthorizedError" },
					"500": { "$ref": "#/components/responses/InternalServerError" }
				}
			}
		},
		"/onboarding/brands": {
			"post": {
				"summary": "Create a brand programmatically",
				"description": "Create a brand and persist its prompts/competitors. Anything the caller doesn't supply (competitors, prompts) is auto-generated via the onboarding pipeline. Pure create — fails with 409 if a brand with this brandId already exists; use PATCH /onboarding/brands/{brandId} to top up an existing one. Use generateCompetitors=false / generatePrompts=false to skip generation entirely.",
				"operationId": "onboardBrand",
				"tags": ["Onboarding"],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/OnboardBrandRequest" }
						}
					}
				},
				"responses": {
					"201": {
						"description": "Brand onboarded",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/OnboardBrandResponse" }
							}
						}
					},
					"400": { "$ref": "#/components/responses/ValidationError" },
					"401": { "$ref": "#/components/responses/UnauthorizedError" },
					"409": { "$ref": "#/components/responses/ConflictError" },
					"500": { "$ref": "#/components/responses/InternalServerError" }
				}
			}
		},
		"/onboarding/brands/{brandId}": {
			"patch": {
				"summary": "Update an onboarded brand",
				"description": "Top up an existing brand with additional domains, aliases, competitors, or prompts. Merges into existing arrays and dedupes net-new competitors/prompts against the database. Returns 404 if the brand doesn't exist — use POST /onboarding/brands to create one.",
				"operationId": "updateOnboardedBrand",
				"tags": ["Onboarding"],
				"parameters": [
					{
						"name": "brandId",
						"in": "path",
						"required": true,
						"description": "Brand identifier",
						"schema": { "type": "string", "minLength": 1 }
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": { "$ref": "#/components/schemas/UpdateOnboardedBrandRequest" }
						}
					}
				},
				"responses": {
					"200": {
						"description": "Brand updated",
						"content": {
							"application/json": {
								"schema": { "$ref": "#/components/schemas/OnboardBrandResponse" }
							}
						}
					},
					"400": { "$ref": "#/components/responses/ValidationError" },
					"401": { "$ref": "#/components/responses/UnauthorizedError" },
					"404": { "$ref": "#/components/responses/NotFoundError" },
					"500": { "$ref": "#/components/responses/InternalServerError" }
				}
			}
		},
		"/prompts": {
			"get": {
				"summary": "List all prompts",
				"description": "Retrieve a paginated list of all prompts across all brands",
				"operationId": "listPrompts",
				"tags": ["Prompts"],
				"parameters": [
					{
						"name": "brandId",
						"in": "query",
						"description": "Filter prompts by brand ID",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "page",
						"in": "query",
						"description": "Page number for pagination (1-based)",
						"required": false,
						"schema": {
							"type": "integer",
							"minimum": 1,
							"default": 1
						}
					},
					{
						"name": "limit",
						"in": "query",
						"description": "Number of items per page",
						"required": false,
						"schema": {
							"type": "integer",
							"minimum": 1,
							"maximum": 100,
							"default": 20
						}
					}
				],
				"responses": {
					"200": {
						"description": "List of prompts",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"prompts": {
											"type": "array",
											"items": {
												"$ref": "#/components/schemas/Prompt"
											}
										},
										"pagination": {
											"type": "object",
											"properties": {
												"page": {
													"type": "integer"
												},
