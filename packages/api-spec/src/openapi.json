		"/reports/{reportId}": {
			"get": {
				"summary": "Get report status and data",
				"description": "Poll a report's status. When completed, returns per-prompt snapshot data with raw mention counts. Consumers are responsible for computing SoV and other derived metrics from the raw data.",
				"operationId": "getReport",
				"tags": ["Reports"],
				"parameters": [
					{
						"name": "reportId",
						"in": "path",
						"required": true,
						"description": "The ID of the report",
						"schema": {
							"type": "string",
							"format": "uuid"
						}
					},
					{
						"name": "kMentions",
						"in": "query",
						"required": false,
						"description": "Number of top competitor entities to return in each prompt's mentionsTopK",
						"schema": {
							"type": "integer",
							"minimum": 1,
							"maximum": 50,
							"default": 5
						}
					}
				],
				"responses": {
					"200": {
						"description": "Report status and data. When status is 'completed', includes per-prompt snapshot data with raw mention counts.",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"reportId": {
											"type": "string",
											"format": "uuid"
										},
										"status": {
											"type": "string",
											"enum": ["pending", "processing", "completed", "failed"]
										},
										"progress": {
											"type": "integer",
											"description": "Generation progress percentage (0-100). Available while processing."
										},
										"brandName": {
											"type": "string"
										},
										"brandWebsite": {
											"type": "string"
										},
										"createdAt": {
											"type": "string",
											"format": "date-time"
										},
										"completedAt": {
											"type": "string",
											"format": "date-time",
											"nullable": true
										},
										"prompts": {
											"type": "array",
											"items": {
												"$ref": "#/components/schemas/ReportPromptSnapshot"
											},
											"description": "Per-prompt snapshot data. Only present when status is 'completed'."
										},
										"unstable": {
											"type": "object",
											"description": "Derived stats (SoV, visibility, etc.). Format may change between versions. Only present when status is 'completed'.",
											"properties": {
												"sov": {
													"type": "number",
													"nullable": true,
													"minimum": 0,
													"maximum": 1,
													"description": "Overall share of voice (0-1): brand_mentions / (brand_mentions + competitor_mentions). Null when no mentions at all."
												},
												"visibility": {
													"type": "number",
													"minimum": 0,
													"maximum": 1,
													"description": "Brand visibility (0-1): brand_mentions / total_prompt_runs (how often the brand appears at all across all prompt runs)"
												},
												"totalPrompts": {
													"type": "integer",
													"description": "Total number of prompts evaluated"
												},
												"totalPromptRuns": {
													"type": "integer",
													"description": "Total number of prompt runs across all prompts (each prompt is executed multiple times across different AI engines)"
												},
												"promptsWithBrandMentions": {
													"type": "integer",
													"description": "Number of prompts where the brand was mentioned in at least one prompt run"
												},
												"promptRunsWithBrandMentions": {
													"type": "integer",
													"description": "Number of individual prompt runs where the brand was mentioned"
												},
												"competitors": {
													"type": "array",
													"items": {
														"type": "object",
														"properties": {
															"name": { "type": "string", "description": "Competitor name" },
															"sov": { "type": "number", "minimum": 0, "maximum": 1, "description": "Share of voice (0-1): this competitor's mentions / total mentions (brand + all competitors)" },
															"visibility": { "type": "number", "minimum": 0, "maximum": 1, "description": "Visibility (0-1): prompt runs mentioning this competitor / total prompt runs" },
															"promptsWithMentions": { "type": "integer", "description": "Number of prompts where this competitor was mentioned in at least one run" },
															"promptRunsWithMentions": { "type": "integer", "description": "Number of individual prompt runs where this competitor was mentioned" }
														},
														"required": ["name", "sov", "visibility", "promptsWithMentions", "promptRunsWithMentions"]
													},
													"description": "Per-competitor SoV breakdown, sorted by SoV descending"
												}
											}
										}
									},
									"required": ["reportId", "status", "brandName", "brandWebsite", "createdAt"]
								},
								"example": {
									"reportId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
									"status": "completed",
									"brandName": "Acme Corp",
									"brandWebsite": "acme.com",
									"createdAt": "2026-04-08T10:00:00Z",
									"completedAt": "2026-04-08T10:05:00Z",
									"prompts": [
										{
											"promptValue": "best project management tools",
											"totalRuns": 4,
											"mentions": {
												"mentionsTotal": 7,
												"brandMentionsTotal": 3,
												"competitorMentionsTotal": 4,
												"mentionsTopK": [
													{ "entity": "Competitor A", "count": 2 },
													{ "entity": "Competitor B", "count": 2 }
												]
											}
										}
									],
									"unstable": {
										"sov": 0.42,
										"visibility": 0.6,
										"totalPrompts": 70,
										"totalPromptRuns": 280,
										"promptsWithBrandMentions": 28,
										"promptRunsWithBrandMentions": 168,
										"competitors": [
											{ "name": "Competitor A", "sov": 0.35, "visibility": 0.35, "promptsWithMentions": 45, "promptRunsWithMentions": 98 },
											{ "name": "Competitor B", "sov": 0.15, "visibility": 0.15, "promptsWithMentions": 20, "promptRunsWithMentions": 42 }
										]
									}
								}
							}
						}
					},
					"400": {
						"$ref": "#/components/responses/ValidationError"
					},
					"401": {
						"$ref": "#/components/responses/UnauthorizedError"
					},
					"404": {
						"$ref": "#/components/responses/NotFoundError"
					},
					"500": {
						"$ref": "#/components/responses/InternalServerError"
					}
				}
			}
		}
	},
