{
	"openapi": "3.0.3",
	"info": {
		"title": "API",
		"description": "API for managing prompts.",
		"version": "1.0.0",
		"contact": {
			"name": "API Support"
		}
	},
	"servers": [
		{
			"url": "/api/v1",
			"description": "API"
		}
	],
	"security": [
		{
			"BearerAuth": []
		}
	],
	"components": {
		"securitySchemes": {
			"BearerAuth": {
				"type": "http",
				"scheme": "bearer",
				"description": "Bearer API token for access"
			}
		},
		"schemas": {
			"Prompt": {
				"type": "object",
				"properties": {
					"id": {
						"type": "string",
						"format": "uuid",
						"description": "Unique identifier for the prompt"
					},
					"brandId": {
						"type": "string",
						"description": "Brand identifier this prompt belongs to"
					},
					"value": {
						"type": "string",
						"description": "The actual prompt text"
					},
					"enabled": {
						"type": "boolean",
						"description": "Whether the prompt is currently enabled"
					},
					"tags": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "User-defined tags for categorizing this prompt"
					},
					"systemTags": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "Auto-computed system tags (e.g., 'branded', 'unbranded'). Read-only."
					},
					"createdAt": {
						"type": "string",
						"format": "date-time",
						"description": "Timestamp when the prompt was created"
					},
					"updatedAt": {
						"type": "string",
						"format": "date-time",
						"description": "Timestamp when the prompt was last updated"
					}
				},
				"required": ["id", "brandId", "value", "enabled", "tags", "systemTags", "createdAt", "updatedAt"]
			},
			"CreatePromptRequest": {
				"type": "object",
				"properties": {
					"brandId": {
						"type": "string",
						"description": "Brand identifier this prompt belongs to"
					},
					"value": {
						"type": "string",
						"description": "The prompt text",
						"minLength": 1
					},
					"tags": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "User-defined tags for categorizing this prompt"
					}
				},
				"required": ["brandId", "value"]
			},
			"UpdatePromptRequest": {
				"type": "object",
				"properties": {
					"value": {
						"type": "string",
						"description": "The prompt text",
						"minLength": 1
					},
					"enabled": {
						"type": "boolean",
						"description": "Whether the prompt is enabled"
					},
					"tags": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"description": "User-defined tags for categorizing this prompt"
					}
				}
			},
			"Error": {
				"type": "object",
				"properties": {
					"error": {
						"type": "string",
						"description": "Error type"
					},
					"message": {
						"type": "string",
						"description": "Detailed error message"
					}
				},
				"required": ["error"]
			},
			"SuccessMessage": {
				"type": "object",
				"properties": {
					"message": {
						"type": "string",
						"description": "Success message"
					},
					"data": {
						"type": "object",
						"description": "Additional response data"
					}
				},
				"required": ["message"]
			},
			"MentionEntry": {
				"type": "object",
				"properties": {
					"entity": {
						"type": "string",
						"description": "Competitor entity name"
					},
					"count": {
						"type": "integer",
						"description": "Number of runs where this entity was mentioned"
					}
				},
				"required": ["entity", "count"]
			},
			"CitedUrlEntry": {
				"type": "object",
				"properties": {
					"url": {
						"type": "string",
						"description": "The cited URL"
					},
					"title": {
						"type": "string",
						"nullable": true,
						"description": "Page title if available"
					},
					"count": {
						"type": "integer",
						"description": "Number of times this URL was cited"
					}
				},
				"required": ["url", "title", "count"]
			},
			"PromptSnapshot": {
				"type": "object",
				"properties": {
					"brandId": {
						"type": "string",
						"description": "Brand identifier this prompt belongs to"
					},
					"promptId": {
						"type": "string",
						"format": "uuid",
						"description": "Unique identifier for the prompt"
					},
					"promptValue": {
						"type": "string",
						"description": "The prompt text"
					},
					"startDate": {
						"type": "string",
						"format": "date",
						"description": "Start of the queried date range (YYYY-MM-DD)"
					},
					"endDate": {
						"type": "string",
						"format": "date",
						"description": "End of the queried date range (YYYY-MM-DD)"
					},
					"mentions": {
						"type": "object",
						"properties": {
							"mentionsTotal": {
								"type": "integer",
								"description": "Total number of prompt evaluation runs in the date range"
							},
							"brandMentionsTotal": {
								"type": "integer",
								"description": "Number of runs where the brand was mentioned"
							},
							"competitorMentionsTotal": {
								"type": "integer",
								"description": "Number of runs where at least one competitor was mentioned"
							},
							"mentionsTopK": {
								"type": "array",
								"items": {
									"$ref": "#/components/schemas/MentionEntry"
								},
								"description": "Top-K competitor entities ranked by mention count"
							}
						},
						"required": ["mentionsTotal", "brandMentionsTotal", "competitorMentionsTotal", "mentionsTopK"]
					},
					"citations": {
						"type": "object",
						"properties": {
							"citationsTotal": {
								"type": "integer",
								"description": "Total number of citations across all runs"
							},
							"brandCitationsTotal": {
								"type": "integer",
								"description": "Number of citations to brand-owned domains"
							},
							"competitorCitationsTotal": {
								"type": "integer",
								"description": "Number of citations to competitor-owned domains"
							},
							"citedUrlsTopK": {
								"type": "array",
								"items": {
									"$ref": "#/components/schemas/CitedUrlEntry"
								},
								"description": "Top-K cited URLs ranked by frequency"
							}
						},
						"required": ["citationsTotal", "brandCitationsTotal", "competitorCitationsTotal", "citedUrlsTopK"]
					}
				},
				"required": ["brandId", "promptId", "promptValue", "startDate", "endDate", "mentions", "citations"]
			}
		},
		"responses": {
			"UnauthorizedError": {
				"description": "Authentication required",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			},
			"NotFoundError": {
				"description": "Resource not found",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			},
			"ValidationError": {
				"description": "Invalid request data",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			},
			"InternalServerError": {
				"description": "Internal server error",
				"content": {
					"application/json": {
						"schema": {
							"$ref": "#/components/schemas/Error"
						}
					}
				}
			}
		}
	},
	"paths": {
		"/prompts": {
			"get": {
				"summary": "List all prompts",
				"description": "Retrieve a paginated list of all prompts across all brands",
				"operationId": "listPrompts",
				"tags": ["Prompts"],
				"parameters": [
					{
						"name": "brandId",
						"in": "query",
						"description": "Filter prompts by brand ID",
						"required": false,
						"schema": {
							"type": "string"
						}
					},
					{
						"name": "page",
						"in": "query",
						"description": "Page number for pagination (1-based)",
						"required": false,
						"schema": {
							"type": "integer",
							"minimum": 1,
							"default": 1
						}
					},
					{
						"name": "limit",
						"in": "query",
						"description": "Number of items per page",
						"required": false,
						"schema": {
							"type": "integer",
							"minimum": 1,
							"maximum": 100,
							"default": 20
						}
					}
				],
				"responses": {
					"200": {
						"description": "List of prompts",
						"content": {
							"application/json": {
								"schema": {
									"type": "object",
									"properties": {
										"prompts": {
											"type": "array",
											"items": {
												"$ref": "#/components/schemas/Prompt"
											}
										},
										"pagination": {
											"type": "object",
											"properties": {
												"page": {
													"type": "integer"
												},
												"limit": {
													"type": "integer"
												},
												"total": {
													"type": "integer"
												},
												"totalPages": {
													"type": "integer"
												}
											}
										}
									}
								}
							}
						}
					},
					"401": {
						"$ref": "#/components/responses/UnauthorizedError"
					},
					"500": {
						"$ref": "#/components/responses/InternalServerError"
					}
				}
			},
			"post": {
				"summary": "Create a new prompt",
				"description": "Create a new prompt for a brand. This will automatically schedule the prompt for execution.",
				"operationId": "createPrompt",
				"tags": ["Prompts"],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/CreatePromptRequest"
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Prompt created successfully",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Prompt"
								}
							}
						}
					},
					"400": {
						"$ref": "#/components/responses/ValidationError"
					},
					"401": {
						"$ref": "#/components/responses/UnauthorizedError"
					},
					"500": {
						"$ref": "#/components/responses/InternalServerError"
					}
				}
			}
		},
		"/prompts/{promptId}/snapshot": {
			"get": {
				"summary": "Get prompt snapshot",
				"description": "Get an aggregated snapshot of mention and citation analytics for a specific prompt over a date range. Use this to identify competitive gaps, track brand visibility trends, and discover top cited URLs.",
				"operationId": "getPromptSnapshot",
				"tags": ["Snapshots"],
				"parameters": [
					{
						"name": "promptId",
						"in": "path",
						"required": true,
						"description": "The ID of the prompt",
						"schema": {
							"type": "string",
							"format": "uuid"
						}
					},
					{
						"name": "startDate",
						"in": "query",
						"required": true,
						"description": "Start of date range (YYYY-MM-DD)",
						"schema": {
							"type": "string",
							"format": "date"
						},
						"example": "2026-01-08"
					},
					{
						"name": "endDate",
						"in": "query",
						"required": true,
						"description": "End of date range (YYYY-MM-DD)",
						"schema": {
							"type": "string",
							"format": "date"
						},
						"example": "2026-01-15"
					},
					{
						"name": "kMentions",
						"in": "query",
						"required": false,
						"description": "Number of top competitor entities to return in mentionsTopK",
						"schema": {
							"type": "integer",
							"minimum": 1,
							"maximum": 50,
							"default": 5
						}
					},
					{
						"name": "kCitations",
						"in": "query",
						"required": false,
						"description": "Number of top cited URLs to return in citedUrlsTopK",
						"schema": {
							"type": "integer",
							"minimum": 1,
							"maximum": 50,
							"default": 10
						}
					}
				],
				"responses": {
					"200": {
						"description": "Prompt snapshot with mention and citation analytics",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/PromptSnapshot"
								},
								"example": {
									"brandId": "brand_nike",
									"promptId": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
									"promptValue": "best running shoes for marathon training",
									"startDate": "2026-01-08",
									"endDate": "2026-01-15",
									"mentions": {
										"mentionsTotal": 210,
										"brandMentionsTotal": 42,
										"competitorMentionsTotal": 130,
										"mentionsTopK": [
											{ "entity": "Adidas", "count": 58 },
											{ "entity": "New Balance", "count": 45 },
											{ "entity": "ASICS", "count": 27 }
										]
									},
									"citations": {
										"citationsTotal": 1240,
										"brandCitationsTotal": 85,
										"competitorCitationsTotal": 620,
										"citedUrlsTopK": [
											{
												"url": "https://www.runnersworld.com/gear/best-running-shoes/",
												"title": "Best Running Shoes 2026",
												"count": 72
											},
											{
												"url": "https://www.nike.com/running/marathon",
												"title": "Nike Marathon Collection",
												"count": 34
											}
										]
									}
								}
							}
						}
					},
					"400": {
						"$ref": "#/components/responses/ValidationError"
					},
					"401": {
						"$ref": "#/components/responses/UnauthorizedError"
					},
					"404": {
						"$ref": "#/components/responses/NotFoundError"
					},
					"500": {
						"$ref": "#/components/responses/InternalServerError"
					}
				}
			}
		},
		"/prompts/{promptId}": {
			"get": {
				"summary": "Get a prompt",
				"description": "Retrieve a specific prompt by ID",
				"operationId": "getPrompt",
				"tags": ["Prompts"],
				"parameters": [
					{
						"name": "promptId",
						"in": "path",
						"required": true,
						"description": "The ID of the prompt",
						"schema": {
							"type": "string",
							"format": "uuid"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Prompt details",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Prompt"
								}
							}
						}
					},
					"401": {
						"$ref": "#/components/responses/UnauthorizedError"
					},
					"404": {
						"$ref": "#/components/responses/NotFoundError"
					},
					"500": {
						"$ref": "#/components/responses/InternalServerError"
					}
				}
			},
			"patch": {
				"summary": "Update a prompt",
				"description": "Update a prompt's properties. Only provided fields will be updated.",
				"operationId": "updatePrompt",
				"tags": ["Prompts"],
				"parameters": [
					{
						"name": "promptId",
						"in": "path",
						"required": true,
						"description": "The ID of the prompt to update",
						"schema": {
							"type": "string",
							"format": "uuid"
						}
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/UpdatePromptRequest"
							}
						}
					}
				},
				"responses": {
					"200": {
						"description": "Prompt updated successfully",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/Prompt"
								}
							}
						}
					},
					"400": {
						"$ref": "#/components/responses/ValidationError"
					},
					"401": {
						"$ref": "#/components/responses/UnauthorizedError"
					},
					"404": {
						"$ref": "#/components/responses/NotFoundError"
					},
					"500": {
						"$ref": "#/components/responses/InternalServerError"
					}
				}
			},
			"delete": {
				"summary": "Delete a prompt",
				"description": "Permanently delete a prompt and cancel all related scheduled jobs. This will also cascade delete all associated prompt runs.",
				"operationId": "deletePrompt",
				"tags": ["Prompts"],
				"parameters": [
					{
						"name": "promptId",
						"in": "path",
						"required": true,
						"description": "The ID of the prompt to delete",
						"schema": {
							"type": "string",
							"format": "uuid"
						}
					}
				],
				"responses": {
					"200": {
						"description": "Prompt deleted successfully",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/SuccessMessage"
								}
							}
						}
					},
					"401": {
						"$ref": "#/components/responses/UnauthorizedError"
					},
					"404": {
						"$ref": "#/components/responses/NotFoundError"
					},
					"500": {
						"$ref": "#/components/responses/InternalServerError"
					}
				}
			}
		}
	},
	"tags": [
		{
			"name": "Prompts",
			"description": "Manage brand prompts"
		},
		{
			"name": "Snapshots",
			"description": "Aggregated analytics snapshots for prompts"
		}
	]
}
