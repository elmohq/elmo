meta {
  name: get nike snapshot
  type: http
  seq: 17
}

get {
  url: {{baseUrl}}/api/v1/prompts/{{nikePromptId}}/snapshot?startDate=2000-01-01&endDate=2100-01-01
  body: none
  auth: inherit
}

params:query {
  startDate: 2000-01-01
  endDate: 2100-01-01
}

assert {
  res.status: eq 200
  res.body.citations.citationsTotal: gte 1
}
