{
  "$schema": "https://turborepo.dev/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "APP_BASE_URL",
    "AUTH0_SECRET",
    "AUTH0_DOMAIN",
    "AUTH0_CLIENT_ID",
    "AUTH0_CLIENT_SECRET",
    "AUTH0_AUDIENCE",
    "AUTH0_SCOPE",
    "AUTH0_MGMT_API_DOMAIN",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "UPSTASH_REDIS_ENDPOINT",
    "DATAFORSEO_LOGIN",
    "DATAFORSEO_PASSWORD",
    "OPENAI_API_KEY",
    "ANTHROPIC_API_KEY",
    "TINYBIRD_TOKEN",
    "TINYBIRD_BASE_URL",
    "TINYBIRD_WORKSPACE",
    "DEPLOYMENT_MODE",
    "NEXT_PUBLIC_DEPLOYMENT_MODE",
    "NEXT_PUBLIC_AUTH0_DOMAIN",
    "NEXT_PUBLIC_AUTH0_CLIENT_ID",
    "ADMIN_AUTH0_SUB",
    "ADMIN_API_KEYS",
    "ENVIRONMENT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@workspace/worker#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  }
}
