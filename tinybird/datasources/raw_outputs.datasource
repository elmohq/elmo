DESCRIPTION >
    Full raw JSON outputs from LLM responses. Stored separately for deep analysis
    when needed. JSON is stored as string and compresses well in ClickHouse.
    Auto-expires after 90 days via TTL.

SCHEMA >
    `prompt_run_id` String `json:$.prompt_run_id`,
    `brand_id` String `json:$.brand_id`,
    `model_group` LowCardinality(String) `json:$.model_group`,
    `raw_output` String `json:$.raw_output`,
    `created_at` DateTime64(3, 'UTC') `json:$.created_at`

ENGINE "MergeTree"
ENGINE_PARTITION_KEY "toYYYYMM(toDate(created_at))"
ENGINE_SORTING_KEY "brand_id, created_at"
ENGINE_TTL "toDateTime(created_at) + INTERVAL 90 DAY"

