DESCRIPTION >
    Expanded citations from LLM responses for fast citation analytics.
    Auto-populated via materialized view from prompt_runs.citations array.
    Do not ingest directly - data flows from prompt_runs through citations_mv.

SCHEMA >
    `prompt_run_id` String,
    `prompt_id` String,
    `brand_id` String,
    `model_group` LowCardinality(String),
    `url` String,
    `domain` LowCardinality(String),
    `title` Nullable(String),
    `created_at` DateTime64(3, 'UTC')

ENGINE "MergeTree"
ENGINE_PARTITION_KEY "toYYYYMM(toDate(created_at))"
ENGINE_SORTING_KEY "brand_id, prompt_id, domain, toDate(created_at)"

