DESCRIPTION >
    Pre-extracted citations from LLM responses for fast citation analytics.
    Citations are extracted at ingestion time to avoid JSON parsing at query time.

SCHEMA >
    `prompt_run_id` String `json:$.prompt_run_id`,
    `prompt_id` String `json:$.prompt_id`,
    `brand_id` String `json:$.brand_id`,
    `model_group` LowCardinality(String) `json:$.model_group`,
    `url` String `json:$.url`,
    `domain` LowCardinality(String) `json:$.domain`,
    `title` Nullable(String) `json:$.title`,
    `category` LowCardinality(String) `json:$.category`,
    `created_at` DateTime64(3, 'UTC') `json:$.created_at`

ENGINE "MergeTree"
ENGINE_PARTITION_KEY "toYYYYMM(toDate(created_at))"
ENGINE_SORTING_KEY "brand_id, prompt_id, domain, toDate(created_at)"

FORWARD_QUERY >
    SELECT prompt_run_id, prompt_id, brand_id, model_group, url, domain, title, category, created_at

