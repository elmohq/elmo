DESCRIPTION >
    Pre-expanded citations table populated automatically via materialized view.
    Uses ReplacingMergeTree to handle duplicates from duplicate prompt_runs inserts.
    
    Deduplication strategy: Rows with same (prompt_run_id, citation_idx) are deduplicated,
    keeping the one with latest created_at. The citation_idx preserves duplicate URLs
    within the same prompt_run's array (important for accurate counting).

SCHEMA >
    `prompt_run_id` String,
    `prompt_id` String,
    `brand_id` String,
    `model_group` LowCardinality(String),
    `url` String,
    `domain` LowCardinality(String),
    `title` Nullable(String),
    `citation_idx` UInt16,
    `created_at` DateTime64(3, 'UTC')

ENGINE "ReplacingMergeTree"
ENGINE_PARTITION_KEY "toYYYYMM(toDate(created_at))"
ENGINE_SORTING_KEY "brand_id, prompt_id, prompt_run_id, citation_idx"
ENGINE_VER "created_at"

