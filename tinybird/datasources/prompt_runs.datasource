DESCRIPTION >
    Core events table for LLM prompt runs. Contains flattened event stream
    optimized for analytics queries with denormalized prompt metadata for fast filtering.
    Includes full-text search index on text_content.

SCHEMA >
    `id` String `json:$.id`,
    `prompt_id` String `json:$.prompt_id`,
    `brand_id` String `json:$.brand_id`,
    `brand_name` String `json:$.brand_name`,
    `prompt_value` String `json:$.prompt_value`,
    `prompt_group_category` Nullable(String) `json:$.prompt_group_category`,
    `prompt_group_prefix` Nullable(String) `json:$.prompt_group_prefix`,
    `prompt_tags` Array(String) `json:$.prompt_tags[:]`,
    `prompt_system_tags` Array(String) `json:$.prompt_system_tags[:]`,
    `model_group` LowCardinality(String) `json:$.model_group`,
    `model` LowCardinality(String) `json:$.model`,
    `web_search_enabled` UInt8 `json:$.web_search_enabled`,
    `brand_mentioned` UInt8 `json:$.brand_mentioned`,
    `competitors_mentioned` Array(String) `json:$.competitors_mentioned[:]`,
    `web_queries` Array(String) `json:$.web_queries[:]`,
    `text_content` String `json:$.text_content`,
    `created_at` DateTime64(3, 'UTC') `json:$.created_at`,
    `competitor_count` UInt16 `json:$.competitor_count`,
    `has_competitor_mention` UInt8 `json:$.has_competitor_mention`

INDEXES >
    text_content_idx text_content TYPE tokenbf_v1(32768, 3, 0) GRANULARITY 4

ENGINE "MergeTree"
ENGINE_PARTITION_KEY "toYYYYMM(toDate(created_at))"
ENGINE_SORTING_KEY "brand_id, prompt_id, toDate(created_at), created_at"

FORWARD_QUERY >
    SELECT id, prompt_id, brand_id, brand_name, prompt_value, prompt_group_category, prompt_group_prefix, prompt_tags, prompt_system_tags, model_group, model, web_search_enabled, brand_mentioned, competitors_mentioned, web_queries, text_content, created_at, competitor_count, has_competitor_mention

